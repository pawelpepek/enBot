<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:enBot.ViewModels"
        xmlns:models="using:enBot.Models"
        xmlns:converters="using:enBot.Converters"
        x:Class="enBot.Views.NotificationWindow"
        x:DataType="vm:NotificationViewModel"
        Width="420"
        SizeToContent="Height"
        ShowInTaskbar="False"
        Topmost="True"
        CanResize="False"
        ShowActivated="False"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur, Blur, None">

    <Window.Resources>
        <converters:ScoreToColorConverter x:Key="ScoreToColor"/>
        <converters:ComplexityToColorConverter x:Key="ComplexityToColor"/>
        <converters:BoldIfTrueConverter x:Key="BoldIfTrue"/>
        <converters:ItalicIfTrueConverter x:Key="ItalicIfTrue"/>
    </Window.Resources>

    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            CornerRadius="10"
            BoxShadow="0 4 20 0 #40000000">
        <Grid RowDefinitions="Auto,Auto,Auto" Margin="16">

            <!-- Header row: title + language + score + complexity badges -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Text="enBot"
                           FontWeight="SemiBold"
                           FontSize="15"
                           VerticalAlignment="Center"/>

                <!-- Language badge -->
                <Border Grid.Column="1"
                        Background="#607D8B"
                        CornerRadius="10"
                        Padding="8,3"
                        Margin="6,0">
                    <TextBlock Text="{Binding Language}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                </Border>

                <!-- Score badge -->
                <Border Grid.Column="2"
                        Background="{Binding Score, Converter={StaticResource ScoreToColor}}"
                        CornerRadius="10"
                        Padding="8,3"
                        Margin="0,0,6,0"
                        ToolTip.Tip="Grammar score">
                    <TextBlock Text="{Binding ScoreText}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="Bold"/>
                </Border>

                <!-- Complexity badge -->
                <Border Grid.Column="3"
                        Background="{Binding Complexity, Converter={StaticResource ComplexityToColor}}"
                        CornerRadius="10"
                        Padding="8,3"
                        ToolTip.Tip="Linguistic complexity">
                    <TextBlock Text="{Binding ComplexityText}"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="Bold"/>
                </Border>
            </Grid>

            <!-- Scrollable body: Corrected, Original, Explanations -->
            <ScrollViewer Grid.Row="1"
                          MaxHeight="420"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,12,0,0">
                <StackPanel>

                    <!-- Corrected with bold highlights -->
                    <StackPanel>
                        <TextBlock Text="Corrected"
                                   FontSize="12"
                                   Opacity="0.55"
                                   Margin="0,0,0,3"/>
                        <ItemsControl ItemsSource="{Binding CorrectedInlines}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:InlineSegment">
                                    <TextBlock Text="{Binding Text}"
                                               FontSize="15"
                                               FontWeight="{Binding IsBold, Converter={StaticResource BoldIfTrue}}"
                                               FontStyle="{Binding IsItalic, Converter={StaticResource ItalicIfTrue}}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Original -->
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="Original"
                                   FontSize="12"
                                   Opacity="0.55"
                                   Margin="0,0,0,3"/>
                        <ItemsControl ItemsSource="{Binding OriginalInlines}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:InlineSegment">
                                    <TextBlock Text="{Binding Text}"
                                               FontSize="15"
                                               FontWeight="{Binding IsBold, Converter={StaticResource BoldIfTrue}}"
                                               FontStyle="{Binding IsItalic, Converter={StaticResource ItalicIfTrue}}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Explanations -->
                    <StackPanel IsVisible="{Binding HasExplanations}" Margin="0,10,0,0">
                        <TextBlock Text="Explanations"
                                   FontSize="12"
                                   Opacity="0.55"
                                   Margin="0,0,0,3"/>
                        <ItemsControl ItemsSource="{Binding Explanations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding}" Margin="0,0,0,4">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:InlineSegment">
                                                <TextBlock Text="{Binding Text}"
                                                           FontSize="14"
                                                           FontWeight="{Binding IsBold, Converter={StaticResource BoldIfTrue}}"
                                                           FontStyle="{Binding IsItalic, Converter={StaticResource ItalicIfTrue}}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Better version -->
                    <StackPanel IsVisible="{Binding HasBetterVersion}" Margin="0,10,0,0">
                        <TextBlock Text="How can we do this better?"
                                   FontSize="12"
                                   Opacity="0.55"
                                   Margin="0,0,0,3"/>
                        <ItemsControl ItemsSource="{Binding BetterVersionInlines}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:InlineSegment">
                                    <TextBlock Text="{Binding Text}"
                                               FontSize="15"
                                               FontWeight="{Binding IsBold, Converter={StaticResource BoldIfTrue}}"
                                               FontStyle="{Binding IsItalic, Converter={StaticResource ItalicIfTrue}}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer: keep open + close -->
            <Grid Grid.Row="2" Margin="0,12,0,0" ColumnDefinitions="*,Auto,Auto">
                <Button Grid.Column="1"
                        Content="Keep open"
                        Padding="12,4"
                        Margin="0,0,8,0"
                        x:Name="KeepOpenButton"/>
                <Button Grid.Column="2"
                        Content="Close"
                        Padding="12,4"
                        x:Name="CloseButton"/>
            </Grid>
        </Grid>
    </Border>
</Window>
