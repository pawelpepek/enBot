<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:enBot.ViewModels"
        xmlns:views="using:enBot.Views"
        x:Class="enBot.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="enBot"
        Width="900" Height="620"
        MinWidth="700" MinHeight="450">

    <TabControl>

        <TabItem Header="Dashboard">
            <views:DashboardView DataContext="{Binding Dashboard}"/>
        </TabItem>

        <TabItem Header="Suggestions">
            <views:PromptSuggestionsView DataContext="{Binding Suggestions}"/>
        </TabItem>

        <TabItem Header="Reports">
            <views:ReportView DataContext="{Binding Report}"/>
        </TabItem>

        <TabItem Header="Settings">
            <views:SettingsView DataContext="{Binding Settings}"/>
        </TabItem>

    </TabControl>

</Window>
