<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:enBot.ViewModels"
             x:Class="enBot.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16" MaxWidth="500">

            <Grid ColumnDefinitions="*,Auto,*">

                <!-- Managing Agents -->
                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock Text="Managing Agents"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <CheckBox Content="Claude Code"
                              IsChecked="{Binding IsClaudeMonitored}"/>
                    <TextBlock Text="Claude Code not found on PATH"
                               FontSize="11"
                               Opacity="0.55"
                               IsVisible="{Binding !IsClaudeAvailable}"/>
                    <CheckBox Content="Codex"
                              IsChecked="{Binding IsCodexMonitored}"/>
                    <TextBlock Text="Codex not found on PATH"
                               FontSize="11"
                               Opacity="0.55"
                               IsVisible="{Binding !IsCodexAvailable}"/>
                </StackPanel>

                <Rectangle Grid.Column="1" Width="1" Margin="16,0"
                           Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.3"/>

                <!-- Analysis Provider -->
                <StackPanel Grid.Column="2" Spacing="8">
                    <TextBlock Text="Analysis Provider"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <RadioButton Content="Claude Code"
                                 IsChecked="{Binding IsClaudeSelected}"
                                 IsEnabled="{Binding IsClaudeAvailable}"
                                 GroupName="Provider"/>
                    <TextBlock Text="Claude Code not found on PATH"
                               FontSize="11"
                               Opacity="0.55"
                               IsVisible="{Binding !IsClaudeAvailable}"/>
                    <RadioButton Content="Codex"
                                 IsChecked="{Binding IsCodexSelected}"
                                 IsEnabled="{Binding IsCodexAvailable}"
                                 GroupName="Provider"/>
                    <TextBlock Text="Codex not found on PATH"
                               FontSize="11"
                               Opacity="0.55"
                               IsVisible="{Binding !IsCodexAvailable}"/>
                </StackPanel>

            </Grid>

            <Rectangle Height="1" Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.3"/>

            <TextBlock Text="User Profile"
                       FontSize="16"
                       FontWeight="SemiBold"/>

            <StackPanel Spacing="6">
                <TextBlock Text="Describe yourself — used to personalise analysis reports"
                           FontSize="11"
                           Opacity="0.55"/>
                <TextBox Text="{Binding UserProfile}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="72"
                         Watermark="e.g. I am a full-stack developer interested in .NET and Angular"/>
            </StackPanel>

            <Rectangle Height="1" Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.3"/>

            <TextBlock Text="Prompt Suggestions"
                       FontSize="16"
                       FontWeight="SemiBold"/>

            <StackPanel Spacing="6">
                <TextBlock Text="Show suggestion notification every N corrections (0 = disabled)"
                           FontSize="11"
                           Opacity="0.55"/>
                <NumericUpDown Value="{Binding SuggestionInterval}"
                               Minimum="0" Maximum="100" Increment="1"
                               FormatString="0"
                               Width="100"
                               HorizontalAlignment="Left"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>
