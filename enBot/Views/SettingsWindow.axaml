<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:enBot.ViewModels"
        x:Class="enBot.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="enBot — Settings"
        Width="560" Height="420"
        CanResize="False">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="24" RowSpacing="12">

        <TextBlock Grid.Row="0"
                   Text="Install Hook"
                   FontSize="16"
                   FontWeight="SemiBold"/>

        <TextBlock Grid.Row="1"
                   Text="Select a project folder to install the enBot hook. This will create .claude/hooks/index.js and register it in .claude/settings.json."
                   TextWrapping="Wrap"
                   Opacity="0.65"/>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Text="{Binding SelectedFolder}"
                     Watermark="Select project folder..."
                     IsReadOnly="True"/>
            <Button Grid.Column="1"
                    Content="Browse..."
                    x:Name="BrowseButton"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <Button Content="Install Hook"
                    Command="{Binding InstallHookCommand}"/>
            <Button Content="Install for User"
                    Command="{Binding InstallForUserCommand}"/>
        </StackPanel>

        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   Opacity="0.7"
                   FontSize="12"
                   TextWrapping="Wrap"/>

        <Rectangle Grid.Row="5" Height="1" Fill="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.3" Margin="0,4,0,0"/>

        <TextBlock Grid.Row="6"
                   Text="Analysis Provider"
                   FontSize="16"
                   FontWeight="SemiBold"/>

        <StackPanel Grid.Row="7" Spacing="8">
            <RadioButton Content="Claude Code (claude --print)"
                         IsChecked="{Binding IsClaudeSelected}"
                         IsEnabled="{Binding IsClaudeAvailable}"
                         GroupName="Provider"/>
            <TextBlock Text="Claude Code not found on PATH"
                       FontSize="11"
                       Opacity="0.55"
                       IsVisible="{Binding !IsClaudeAvailable}"/>
            <RadioButton Content="Codex (codex exec)"
                         IsChecked="{Binding IsCodexSelected}"
                         IsEnabled="{Binding IsCodexAvailable}"
                         GroupName="Provider"/>
            <TextBlock Text="Codex not found on PATH"
                       FontSize="11"
                       Opacity="0.55"
                       IsVisible="{Binding !IsCodexAvailable}"/>
        </StackPanel>
    </Grid>
</Window>
